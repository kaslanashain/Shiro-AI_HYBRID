# Ollama chat model (avoid coder models for roleplay)
OLLAMA_MODEL=qwen2.5:7b

# Optional: Google Gemini for image vision
GEMINI_API_KEY=

# Voicevox engine URL (Japanese TTS)
VOICEVOX_URL=http://localhost:50021

# Server
FLASK_DEBUG=false
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# Limits
MAX_CACHE=100
MAX_UPLOAD_BYTES=5242880
